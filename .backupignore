# Backup Ignore File
# This file specifies files and directories that should be excluded from backups
# to reduce backup size while maintaining project functionality

# Dependencies (can be restored with npm install)
node_modules/

# Build output (can be regenerated with npm run build)
dist/

# Wrangler cache (can be regenerated)
.wrangler/

# Development files
.vscode/
.idea/

# Environment files (should not be backed up for security)
.env
.env.production
.dev.vars

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# OS files
.DS_Store
Thumbs.db

# Temporary files
*.tmp
*.temp
*.swp
*.swo
*~

# PM2 files
.pm2/
pids/
